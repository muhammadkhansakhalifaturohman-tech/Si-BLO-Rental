{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "./mvnw clean package -DskipTests"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "java -Xmx256m -XX:MaxMetaspaceSize=128m -XX:+UseSerialGC -jar target/rent-0.0.1-SNAPSHOT.jar --spring.profiles.active=prod",
    "healthcheckPath": "/home",
    "restartPolicyType": "ON_FAILURE"
  }
}
